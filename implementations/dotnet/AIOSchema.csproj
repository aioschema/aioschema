<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>AIOSchema</RootNamespace>
    <AssemblyName>aioschema</AssemblyName>
    <Version>0.5.6</Version>
    <Description>AIOSchema v0.5.6 Reference Implementation — C# / .NET 8</Description>
    <Authors>AIOSchema Authors</Authors>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <None Update="cross_verify_vectors.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
