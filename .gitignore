# AIOSchema monorepo .gitignore
# Generated at repo finalization after all implementations committed.
# Covers: Ruby, JavaScript/Node.js, Go, Rust, TypeScript, Python, .NET

# -----------------------------------------------------------------------
# Ruby / Jekyll
# -----------------------------------------------------------------------
*.gem
*.rbc
/.bundle
/vendor/bundle
/log
/tmp
_site/
.jekyll-cache/
.jekyll-metadata
Gemfile.lock

# -----------------------------------------------------------------------
# JavaScript / Node.js
# -----------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm/
.env

# -----------------------------------------------------------------------
# Go
# -----------------------------------------------------------------------
/bin/
*.exe
*.test
*.out
vendor/

# -----------------------------------------------------------------------
# Rust
# -----------------------------------------------------------------------
/target/
Cargo.lock
_rustc_info.json

# -----------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------
dist/
*.js.map
*.d.ts
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
.venv/
venv/
dist/
*.dist-info/

# -----------------------------------------------------------------------
# .NET
# -----------------------------------------------------------------------
bin/
obj/
*.user
.vs/
*.nupkg
*.snupkg
TestResults/

# -----------------------------------------------------------------------
# OS / Editor
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.orig

# -----------------------------------------------------------------------
# Build artifacts — never commit
# -----------------------------------------------------------------------
_rustc_info.json
*.aios.json
